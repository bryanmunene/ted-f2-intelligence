APP_ENV=development
APP_NAME=cBrain TED F2 Intelligence
APP_SECRET_KEY=change-me-in-production
APP_LOG_LEVEL=INFO
APP_AUTH_ENABLED=false
APP_DEFAULT_USER_EMAIL=f2-intelligence@cbrain.com
APP_DEFAULT_USER_NAME=Internal Analyst
APP_HEADER_AUTH_EMAIL_HEADER=X-Forwarded-Email
APP_HEADER_AUTH_NAME_HEADER=X-Forwarded-User
APP_SESSION_COOKIE_NAME=cbrain_ted_session
APP_SESSION_HTTPS_ONLY=false
APP_UI_TIMEZONE=Europe/Copenhagen
APP_DATABASE_URL=postgresql+psycopg://ted_app:ted_app@postgres:5432/ted_app
APP_SQLALCHEMY_ECHO=false
APP_AUTO_CREATE_SCHEMA=false
APP_TED_API_BASE_URL=https://api.ted.europa.eu
APP_TED_SEARCH_PATH=/v3/notices/search
APP_TED_REQUEST_TIMEOUT_SECONDS=30
APP_TED_RETRY_ATTEMPTS=4
APP_TED_REQUESTS_PER_MINUTE=60
APP_TED_CACHE_TTL_SECONDS=300
APP_TED_DEFAULT_PAGE_SIZE=50
APP_TED_MAX_PAGE_SIZE=250
APP_TED_MAX_PAGES_PER_SCAN=4
APP_TED_SEARCH_SCOPE=ACTIVE
APP_KEYWORD_PACK_PATH=config/keyword_pack.yaml
APP_SEARCH_PROFILES_PATH=config/search_profiles.yaml
APP_SCORING_VERSION=2026.03.2
APP_ANALYSIS_EXTRACTION_VERSION=2026.03.2
